# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=production

# ============================================
# CORS — set to your Flutter app's origin or * for open access
# ============================================
ALLOWED_ORIGINS=*

# ============================================
# DATABASE — Railway PostgreSQL (production)
# ============================================
# Railway provides DATABASE_URL automatically when you add the Postgres addon.
# Alternatively set individual fields:
DATABASE_URL=postgresql://user:password@host:5432/dbname

# For local SQLite demo only (do NOT use on Railway):
# DB_DIALECT=sqlite
# DB_STORAGE=./data/mesmer.sqlite

# ============================================
# JWT AUTHENTICATION — use long random strings in production
# ============================================
JWT_ACCESS_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_different_long_random_secret
JWT_ACCESS_EXPIRE=8h
JWT_REFRESH_EXPIRE=7d

# ============================================
# SECURITY
# ============================================
BCRYPT_ROUNDS=10

# ============================================
# FILE STORAGE (optional — local disk if not set)
# ============================================
# STORAGE_TYPE=s3
# R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=your_key
# R2_SECRET_ACCESS_KEY=your_secret
# R2_BUCKET_NAME=mesmer-files

# ============================================
# SMS (optional — logs to console if not set)
# ============================================
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=your_sid
# TWILIO_AUTH_TOKEN=your_token
# TWILIO_FROM_NUMBER=+1234567890
